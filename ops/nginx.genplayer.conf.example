# Redirect plain HTTP traffic to HTTPS.
server {
    listen 80;
    server_name genplayer.fugary.com;

    location / {
        return 301 https://$host$request_uri;
    }
}

# Serve the static files deployed by GitHub Actions.
server {
    listen 443 ssl http2;
    server_name genplayer.fugary.com;

    ssl_certificate /etc/nginx/ohttps.com/certificates/cert-pzd1287m7jy8jxmy/fullchain.cer;
    ssl_certificate_key /etc/nginx/ohttps.com/certificates/cert-pzd1287m7jy8jxmy/cert.key;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;
    ssl_prefer_server_ciphers on;

    root /var/www/genplayer.fugary.com/current;
    index index.html;

    # Keep the current URL structure unchanged, for example:
    # / -> /index.html
    # /privacy.html
    # /feedback.html
    location / {
        try_files $uri $uri/ =404;
    }

    error_page 404 /404.html;

    # Cache versioned static assets more aggressively.
    location ~* \.(?:css|js|png|jpg|jpeg|gif|svg|ico|webp)$ {
        expires 7d;
        add_header Cache-Control "public, max-age=604800, immutable";
        try_files $uri =404;
    }
}
